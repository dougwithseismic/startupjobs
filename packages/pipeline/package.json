{
  "name": "@repo/pipeline",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "lint": "echo 'no linter configured'",
    "sync": "tsx src/scripts/sync.ts",
    "search": "tsx src/scripts/search.ts",
    "extract": "tsx src/scripts/extract.ts",
    "smoke-test": "tsx src/scripts/smoke-test.ts",
    "eval:search": "tsx src/evals/scripts/run-search-eval.ts",
    "eval:search:judge": "tsx src/evals/scripts/run-search-eval.ts --judge",
    "eval:extraction": "tsx src/evals/scripts/run-extraction-eval.ts",
    "eval": "tsx src/evals/scripts/run-search-eval.ts && tsx src/evals/scripts/run-extraction-eval.ts",
    "visualize": "tsx src/scripts/visualize.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@mastra/core": "^1.35.0",
    "@mastra/evals": "^1.2.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@repo/startupjobs-api": "workspace:^",
    "@repo/typescript-config": "workspace:^",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "mastra": "^1.9.3",
    "tsx": "^4.22.1",
    "typescript": "5.9.2"
  }
}
